---
import "../styles/style.css";
const products = [
  {
    name: "Artwork 1",
    image: "/images/art1.jpg",
    description: "Acrylic painting inspired by nature."
  },
  {
    name: "Artwork 2",
    image: "/images/art2.jpg",
    description: "Handmade ceramic sculpture."
  },
  {
    name: "Artwork 3",
    image: "/images/art3.jpg",
    description: "Abstract oil painting."
  },
  {
    name: "Artwork 4",
    image: "/images/art4.jpg",
    description: "Minimalist ink illustration."
  },
  {
    name: "Artwork 5",
    image: "/images/art5.jpg",
    description: "Mixed media canvas artwork."
  }
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>StoltGallery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bitcount+Prop+Double+Ink:wght@100..900&family=Spectral:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Bitcount+Prop+Double+Ink:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  </head>

  <body class="bg-[#1e1e1e] texture-bg">
    
    <div class="lang-switch">
      <a href="/">🇫🇷</a>
      <span>|</span>
      <a href="/en/">🇬🇧</a>
    </div>

    <!-- Title -->
    <section class="intro">
      <div class="retro-banner">
        <div class="retro-track">
          <div class="retro-content">
            STOLT GALLERY — CURATED WORKS — TIMELESS BEAUTY — FOLLOW @STOLT.GALLERY —
          </div>
      
          <div class="retro-content">
            STOLT GALLERY — CURATED WORKS — TIMELESS BEAUTY — FOLLOW @STOLT.GALLERY —
          </div>
        </div>
      </div>
      <h1>Stolt Gallery</h1>
      <div class="retro-banner retro-banner-bottom">
        <div class="retro-track">
          <div class="retro-content">
            STOLT GALLERY — CURATED WORKS — TIMELESS BEAUTY — FOLLOW @STOLT.GALLERY —
          </div>
      
          <div class="retro-content">
            STOLT GALLERY — CURATED WORKS — TIMELESS BEAUTY — FOLLOW @STOLT.GALLERY —
          </div>
        </div>
      </div>


      <h2>L'histoire</h2>

      <p class="lead">
        Un dialogue entre les siècles, les techniques et les sensibilités.
      </p>

      <p>
        D’un maître italien du XVIIe siècle à un designer suisse du XXIe,
        que peut-il exister en commun ?
      </p>

      <p>
        Stolt Gallery rassemble des œuvres qui partagent un même goût :
        une recherche de beauté intemporelle, indépendante des époques
        et des disciplines.
      </p>

      <p>
        Certaines œuvres sont naïves, d'autres nous poussent à l’introspection.
        Toutes invitent à une rencontre avec un univers intérieur parfois
        insoupçonné.
      </p>

      <p>
        L’art peut nous troubler, nous élever, nous apaiser, ou simplement
        faire taire le brouhaha de l’esprit. La contemplation, ultimement,
        nous renseigne sur nous-mêmes.
      </p>

      <p>
        L’ambition de Stolt est de créer un dialogue harmonieux entre
        les œuvres, leurs artistes et vous.
      </p>
    </section>


    <hr class="divider">


    <!-- Owner Section -->
    <section>
      <h2>À Propos</h2>

      <div class="owner">
        <img src="/images/eric.jpeg" alt="Business owner" />

        <p>
          Hello! I'm the artist behind this gallery. I create handmade artworks
          inspired by nature, everyday life, and imagination. Each piece is
          unique and crafted with care using traditional techniques and
          modern creativity.
        </p>
      </div>
    </section>

    <hr class="divider">

    <!-- Art Gallery -->
    <section>
      <h2>Gallerie</h2>

      <div class="gallery">
        {products.map(product => (
          <figure class="art">
            <img src={product.image} alt={product.name} />
            <figcaption>{product.description}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <p>Follow our latest acquisitions on Instagram</p>

      <a href="https://www.instagram.com/stolt.gallery" target="_blank">
        <i class="fa-brands fa-instagram"></i>
      </a>

      <p style="margin-top:20px;font-size:0.8rem;">
        © {new Date().getFullYear()} Stolt Gallery
      </p>
    </footer>

  </body>
</html>